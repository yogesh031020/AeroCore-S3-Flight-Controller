# FlySky Radio + Telemetry Bridge Defaults
AHRS_EKF_TYPE 3
EK3_ENABLE 1
ARMING_SKIPCHK 16383
ARMING_NEED_LOC 0
EK3_SRC1_YAW 0
EK3_SRC1_POSXY 0
EK3_SRC1_VELXY 0
EK3_SRC1_POSZ 1
# Enable Radio Protocols (1 = All, including iBUS)
RC_PROTOCOLS 1
# SERIAL1 is EMPTY (WiFi disabled), so we use SERIAL3 = UART1 (GPIO 17/18)
SERIAL3_PROTOCOL 2
SERIAL3_BAUD 57600
BRD_SAFETYENABLE 0
